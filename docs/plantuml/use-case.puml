@startuml use-case-vivid
left to right direction
skinparam packageStyle rectangle

actor "Client" as client
actor "Administrateur" as admin

rectangle "Plateforme Vivid" {
  usecase "S'inscrire / Se connecter" as UC1
  usecase "Parcourir le catalogue" as UC2
  usecase "Gérer le panier" as UC3
  usecase "Passer commande" as UC4
  usecase "Gérer les favoris" as UC5
  usecase "Laisser un avis" as UC6
  usecase "Gérer produits et catégories" as UC7
  usecase "Gérer commandes et utilisateurs" as UC8
  usecase "Consulter le dashboard" as UC9
}

client --> UC1
client --> UC2
client --> UC3
client --> UC4
client --> UC5
client --> UC6

admin --> UC1
admin --> UC7
admin --> UC8
admin --> UC9
@enduml
