{
  "info": {
    "name": "Vivid E-Commerce API",
    "description": "Collection API v1 — importer avec l'environnement Vivid Local.\n\nTests automatisés : dossier « 0. Smoke Test (Runner) » ou `./postman/run-newman.sh`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080/api/v1" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.request.headers.upsert({ key: 'Accept', value: 'application/json' });"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "0. Smoke Test (Runner)",
      "description": "Parcours automatisé pour Newman. Exécuter dans l'ordre ou via run-newman.sh",
      "item": [
        {
          "name": "01 - API produits publics",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('Liste paginée', () => pm.expect(j.data).to.be.an('array'));",
                  "if (j.data.length > 0) {",
                  "  pm.environment.set('product_id', j.data[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/products?per_page=5"
          }
        },
        {
          "name": "02 - Login client",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login OK', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('Token présent', () => pm.expect(j.token).to.be.a('string'));",
                  "pm.environment.set('token', j.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"client@shop.com\",\n  \"password\": \"password\"\n}"
            },
            "url": "{{base_url}}/login"
          }
        },
        {
          "name": "03 - Profil /me",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('User retourné', () => pm.expect(pm.response.json().email).to.eql('client@shop.com'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/me"
          }
        },
        {
          "name": "04 - Ajouter au panier",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 ou 201', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));",
                  "const j = pm.response.json();",
                  "const items = j.items || j.data?.items || [];",
                  "if (items.length > 0) pm.environment.set('cart_item_id', items[0].id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_id\": {{product_id}},\n  \"quantity\": 1\n}"
            },
            "url": "{{base_url}}/cart"
          }
        },
        {
          "name": "05 - Voir panier",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "const items = j.items || [];",
                  "pm.test('Panier non vide', () => pm.expect(items.length).to.be.above(0));",
                  "if (items[0]) pm.environment.set('cart_item_id', items[0].id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/cart"
          }
        },
        {
          "name": "06 - Ajouter favori",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 ou 201', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_id\": {{product_id}}\n}"
            },
            "url": "{{base_url}}/wishlist"
          }
        },
        {
          "name": "07 - Passer commande",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Commande créée', () => pm.response.to.have.status(201));",
                  "const j = pm.response.json();",
                  "const order = j.data || j;",
                  "if (order.id) pm.environment.set('order_id', order.id);",
                  "pm.test('Statut commande', () => pm.expect(order.status).to.exist);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shipping_address\": \"123 Avenue Hassan II, Casablanca\",\n  \"payment_method\": \"card\"\n}"
            },
            "url": "{{base_url}}/orders"
          }
        },
        {
          "name": "08 - Login admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login admin OK', () => pm.response.to.have.status(200));",
                  "pm.environment.set('admin_token', pm.response.json().token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@shop.com\",\n  \"password\": \"password\"\n}"
            },
            "url": "{{base_url}}/login"
          }
        },
        {
          "name": "09 - Dashboard admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Admin autorisé', () => pm.response.to.have.status(200));",
                  "pm.test('Stats présentes', () => pm.expect(pm.response.json()).to.be.an('object'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": "{{base_url}}/admin/dashboard"
          }
        },
        {
          "name": "10 - Guest refusé panier",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Non authentifié = 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/cart"
          }
        }
      ]
    },
    {
      "name": "1. Public",
      "item": [
        {
          "name": "Liste produits",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('JSON paginé', () => pm.expect(pm.response.json().data).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/products?per_page=12"
          }
        },
        {
          "name": "Détail produit",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/products/{{product_id}}"
          }
        },
        {
          "name": "Catégories",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/categories"
          }
        },
        {
          "name": "Avis produit (public)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/products/{{product_id}}/reviews"
          }
        }
      ]
    },
    {
      "name": "2. Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password\",\n  \"password_confirmation\": \"password\",\n  \"phone\": \"0600000000\"\n}"
            },
            "url": "{{base_url}}/register"
          }
        },
        {
          "name": "Login Client",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  pm.environment.set('token', pm.response.json().token);",
                  "}",
                  "pm.test('Login OK', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"client@shop.com\",\n  \"password\": \"password\"\n}"
            },
            "url": "{{base_url}}/login"
          }
        },
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  pm.environment.set('admin_token', pm.response.json().token);",
                  "}",
                  "pm.test('Login admin OK', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@shop.com\",\n  \"password\": \"password\"\n}"
            },
            "url": "{{base_url}}/login"
          }
        },
        {
          "name": "Me",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/me"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/logout"
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"client@shop.com\"\n}"
            },
            "url": "{{base_url}}/forgot-password"
          }
        }
      ]
    },
    {
      "name": "3. Panier",
      "item": [
        {
          "name": "Voir panier",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/cart"
          }
        },
        {
          "name": "Ajouter au panier",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Ajout OK', () => pm.expect(pm.response.code).to.be.oneOf([200, 201]));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_id\": 1,\n  \"quantity\": 1\n}"
            },
            "url": "{{base_url}}/cart"
          }
        },
        {
          "name": "Modifier quantité",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"quantity\": 2\n}" },
            "url": "{{base_url}}/cart/{{cart_item_id}}"
          }
        },
        {
          "name": "Supprimer ligne",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/cart/{{cart_item_id}}"
          }
        }
      ]
    },
    {
      "name": "4. Favoris",
      "item": [
        {
          "name": "Liste favoris",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/wishlist"
          }
        },
        {
          "name": "Ajouter favori",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"product_id\": 1\n}" },
            "url": "{{base_url}}/wishlist"
          }
        },
        {
          "name": "Retirer favori",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/wishlist/{{product_id}}"
          }
        }
      ]
    },
    {
      "name": "5. Commandes",
      "item": [
        {
          "name": "Passer commande",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const o = pm.response.json().data || pm.response.json();",
                  "  if (o.id) pm.environment.set('order_id', o.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shipping_address\": \"123 Avenue Hassan II, Casablanca\",\n  \"payment_method\": \"card\",\n  \"coupon_code\": \"WELCOME10\"\n}"
            },
            "url": "{{base_url}}/orders"
          }
        },
        {
          "name": "Mes commandes",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/orders"
          }
        },
        {
          "name": "Détail commande",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/orders/{{order_id}}"
          }
        }
      ]
    },
    {
      "name": "6. Admin",
      "item": [
        {
          "name": "Dashboard",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Admin OK', () => pm.response.to.have.status(200));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": "{{base_url}}/admin/dashboard"
          }
        },
        {
          "name": "Liste produits admin",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": "{{base_url}}/admin/products"
          }
        },
        {
          "name": "Créer produit",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category_id\": 1,\n  \"name\": \"Produit Test API\",\n  \"description\": \"Créé via Postman\",\n  \"price\": 99.99,\n  \"stock\": 10,\n  \"status\": \"active\"\n}"
            },
            "url": "{{base_url}}/admin/products"
          }
        },
        {
          "name": "Changer statut commande",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"processing\"\n}" },
            "url": "{{base_url}}/admin/orders/{{order_id}}/status"
          }
        }
      ]
    }
  ]
}
